{
  "name": "@synnode/expo-metro-mcp",
  "version": "1.0.6",
  "description": "MCP server for Expo/React Native development — live logs, stack trace resolution, runtime evaluation, and simulator/emulator automation via CDP and platform CLIs.",
  "type": "module",
  "bin": {
    "expo-metro-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --minify && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "expo",
    "react-native",
    "metro",
    "simulator",
    "emulator",
    "ios",
    "android",
    "debugging",
    "claude",
    "ai"
  ],
  "author": "Michael Sanders",
  "license": "MIT",
  "homepage": "https://github.com/Synnode/expo-metro-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Synnode/expo-metro-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Synnode/expo-metro-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "source-map": "^0.7.6",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
